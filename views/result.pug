doctype html
html
  head
    meta(charset="utf-8")
    title Registrations
    link(rel="stylesheet" href="/styles.css")
  body
    .container
      h1 All Registrations
      a.back-link(href="/") ← Back to form

      if !data || data.length === 0
        p.no-results No registrations found.
      else
        table.results-table
          thead
            tr
              th id
              th Name
              th Roll
              th Department
              th Year
              th Semester
              th Address
              th Actions
          tbody
            each item in data
              tr
                td= item.id
                td= item.name
                td= item.classRoll
                td= item.department
                td= item.year
                td= item.semester
                td= item.address
                td
                  form(action=`/delete/${item.id}` method="POST" style="border: none; padding: 0; margin: 1;")
                    button(type="submit") Delete

                  form(action=`/edit/${item.id}` method="POST" style="border: none; padding: 0; margin: 1;")
                    button(type="submit") Edit